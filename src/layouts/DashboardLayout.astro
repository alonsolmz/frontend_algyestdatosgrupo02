---
interface Props {
  title: string;
}

const { title } = Astro.props;

// Importación limpia del CSS global para Tailwind v4
import '../styles/global.css'; 
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Sistema de Almacén</title>
  </head>
  <body class="bg-slate-100 text-slate-900 font-sans antialiased min-h-screen flex">
    
    <aside class="w-64 bg-slate-900 text-white flex flex-col fixed h-full shadow-xl z-10">
      <div class="p-5 border-b border-slate-800 flex items-center gap-3">
        <div class="h-8 w-8 rounded-lg bg-blue-500 flex items-center justify-center font-bold text-white text-lg shadow-md">
          A
        </div>
        <div>
          <h1 class="font-bold text-sm tracking-wide">LMZ Almacenes</h1>
          <p class="text-[10px] text-slate-400 font-medium">Panel de Control v1.0</p>
        </div>
      </div>
      
      <nav class="flex-1 p-4 space-y-1.5 text-sm">
        <a href="#" class="flex items-center gap-3 px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          Productos y Stock
        </a>
        <a href="#" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-400 hover:bg-slate-800 hover:text-slate-200 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          Ubicaciones / Estantes
        </a>
        <a href="#" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-400 hover:bg-slate-800 hover:text-slate-200 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 00-2 2h10a2 2 0 00-2-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          Pedidos y Despachos
        </a>
      </nav>

      <div class="p-4 border-t border-slate-800 text-center text-xs text-slate-500 font-medium">
        UTP / UNI - Grupo 02
      </div>
    </aside>

    <div class="flex-1 pl-64 flex flex-col min-h-screen">
      <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 sticky top-0 z-0">
        <div class="flex items-center gap-2 text-sm text-slate-500 font-medium">
          <span>Módulos</span>
          <span>/</span>
          <span class="text-slate-800 font-semibold">{title}</span>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></div>
          <span class="text-xs font-semibold text-slate-600 tracking-wide uppercase">Servidor API Online</span>
        </div>
      </header>

      <main class="p-8 flex-1">
        <slot />
      </main>
    </div>

  </body>
</html>